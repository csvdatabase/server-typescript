# Use latest for explicit pull-based updates, or pin an exact release such as 0.1.0.
CSDB_IMAGE=ghcr.io/csvdatabase/server-typescript
CSDB_VERSION=latest

# Compose binds to localhost by default. Change this only when network access is intentional.
CSDB_BIND_ADDRESS=127.0.0.1
CSDB_PORT=3000
CSDB_DATA_PATH=./data

# Set a long random value before exposing the service outside localhost.
CSDB_API_KEY=

CSDB_MAX_BODY_BYTES=1048576
CSDB_SHUTDOWN_TIMEOUT_MS=10000
CSDB_STOP_GRACE_PERIOD=15s

# On Linux, these must be able to read and write CSDB_DATA_PATH.
CSDB_UID=1000
CSDB_GID=1000

CSDB_PIDS_LIMIT=128
CSDB_LOG_MAX_SIZE=10m
CSDB_LOG_MAX_FILES=3
